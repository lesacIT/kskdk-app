{
  "name": "kskdk-backend",
  "version": "1.0.0",
  "description": "Backend API for Health Examination Management System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:reset": "rm -f kskdk.db && node -e \"require('./database').initDatabase()\"",
    "db:backup": "cp kskdk.db kskdk_backup_$(date +%Y%m%d_%H%M%S).db",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "health-examination",
    "medical",
    "api",
    "express",
    "sqlite"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "sqlite3": "^5.1.6",
    "sqlite": "^5.1.1",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}