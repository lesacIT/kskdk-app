{
  "name": "kskdk-backend",
  "version": "1.0.0",
  "description": "Backend API for Health Examination Management System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:reset": "rm -f kskdk.db && node -e \"require('./database').initDatabase()\"",
    "db:backup": "cp kskdk.db kskdk_backup_$(date +%Y%m%d_%H%M%S).db",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "health-examination",
    "medical",
    "api",
    "express",
    "sqlite"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "connect-sqlite3": "^0.9.16",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0",
    "pdfkit": "^0.18.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}
